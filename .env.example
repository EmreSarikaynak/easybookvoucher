# Kopyalayın: cp .env.example .env
# .env dosyası git'e gitmez (.gitignore). Canlı ortam: Cloudflare Workers → Variables and Secrets

# ─── Supabase (zorunlu) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Sadece sunucu: PDF upload API, WhatsApp log (asla frontend'e koymayın)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── DeepL (opsiyonel — tur içeriği TR→EN/RU/PL otomatik çeviri) ─────────────
# https://www.deepl.com/pro-api adresinden Free planı aç (aylık 500K karakter ücretsiz).
# Free anahtarlar ":fx" ile biter; Pro anahtarlar bitmiyor.
# Tanımlı değilse: tur formundaki "TR'den çevir" butonu hata verir,
#                  kaydetme anındaki otomatik doldurma sessizce atlanır.
# DEEPL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx

# ─── Twilio WhatsApp (zorunlu — PDF + bildirimler) ───────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+1xxxxxxxxxx

# ─── Twilio şablonları (opsiyonel — bilet KAYDI anı, PDF yokken) ─────────────
# Müşteri: TR ve EN ayrı şablon ({{1}} ad, {{2}} bilet no, {{3}} tur, {{4}} tarih).
# TWILIO_VOUCHER_TEMPLATE_SID_TR=
# TWILIO_VOUCHER_TEMPLATE_SID_EN=
# TWILIO_INTERNAL_TEMPLATE_SID=

# ─── Twilio PDF şablonları (ÖNEMLİ — 24 saat penceresi dışı için) ───────────
# Twilio Console → Content Templates'ten oluşturulup WhatsApp onayı alınmış SID'ler.
# Değişkenler: {{1}} ad, {{2}} bilet no, {{3}} tur, {{4}} tarih, {{5}} PDF URL
# Hesapta otomatik oluşturulan + onaylı şablonlar (2026-05):
#   TWILIO_PDF_TEMPLATE_SID_TR=HX0e6bd3d0d29ee86d1c1610a52535e360
#   TWILIO_PDF_TEMPLATE_SID_EN=HX904db708f87cb544eba0e484dcc166a7
#   TWILIO_PDF_INTERNAL_TEMPLATE_SID=HXe26a025a272376c6450b9ae6bec6db84
# Onay gelene kadar geçici TR fallback (4 değişkenli, PDF URL'i içermez):
#   TWILIO_PDF_TEMPLATE_SID_TR=HX19a06ee7ab88346ad976f1495e31e512
#   TWILIO_PDF_INTERNAL_TEMPLATE_SID=HX19a06ee7ab88346ad976f1495e31e512
# TWILIO_PDF_TEMPLATE_SID_TR=
# TWILIO_PDF_TEMPLATE_SID_EN=
# TWILIO_PDF_INTERNAL_TEMPLATE_SID=

# ─── Twilio PDF/JPEG media şablonları (direkt ek dosya için önerilen) ───────
# Content Type: Media, medya URL şablonu:
# https://YOUR_PROJECT.supabase.co/storage/v1/object/public/voucher-pdfs/{{1}}
# Body değişkenleri: {{2}} ad, {{3}} bilet no, {{4}} tur, {{5}} tarih, {{6}} PDF URL
# TWILIO_PDF_MEDIA_TEMPLATE_SID_TR=
# TWILIO_PDF_MEDIA_TEMPLATE_SID_EN=
# TWILIO_PDF_MEDIA_INTERNAL_TEMPLATE_SID=

# ─── Twilio opsiyonel ─────────────────────────────────────────────────────────
# TWILIO_EASYBOOK_PHONE=+905366029397
# TWILIO_STATUS_CALLBACK_URL=https://bodrumdayiz.com.tr/api/webhooks/twilio
# TWILIO_SEND_PDF_AS_MEDIA=true  # varsayılan: JPEG ek; true ise PDF MediaUrl dener

# ─── Web Push / PWA Bildirimleri ──────────────────────────────────────────────
# Oluşturmak için: node scripts/generate-vapid-keys.mjs
# NEXT_PUBLIC_VAPID_PUBLIC_KEY sunucu + tarayıcıda kullanılır (public olabilir)
# VAPID_PRIVATE_KEY sadece sunucuda kalmalı, Cloudflare'e "Encrypt" olarak ekleyin
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BJ8GG0Jo0NNNRvqWEpMALXfItd0f6LUAwzheM4YiymcAm0jPIqzri-PrwkcuqdVZ7YEPlllQOv2cAI0UBdo505M
VAPID_PRIVATE_KEY=VNSvu49ayxd9uI3uu8Db3n0G83IGsyMaw2k17Dk-HOE
# E-posta (bildirimlerde gönderici kimliği olarak kullanılır)
VAPID_SUBJECT=mailto:admin@easybooktours.com
