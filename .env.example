# Kopyalayın: cp .env.example .env
# .env dosyası git'e gitmez (.gitignore). Canlı ortam: Cloudflare Workers → Variables and Secrets

# ─── Supabase (zorunlu) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Sadece sunucu: PDF upload API, WhatsApp log (asla frontend'e koymayın)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Twilio WhatsApp (zorunlu — PDF + bildirimler) ───────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+1xxxxxxxxxx

# ─── Twilio şablonları (opsiyonel — bilet KAYDI anı, PDF yokken) ─────────────
# Müşteri: TR ve EN ayrı şablon ({{1}} ad, {{2}} bilet no, {{3}} tur, {{4}} tarih).
# TWILIO_VOUCHER_TEMPLATE_SID_TR=
# TWILIO_VOUCHER_TEMPLATE_SID_EN=
# TWILIO_INTERNAL_TEMPLATE_SID=

# ─── Twilio PDF şablonları (önerilir — 24 saat penceresi dışı için) ─────────
# WhatsApp hata 63016 almamak için onaylı template gerekir.
# Değişkenler: {{1}} ad, {{2}} bilet no, {{3}} tur, {{4}} tarih, {{5}} PDF URL
# TWILIO_PDF_TEMPLATE_SID_TR=
# TWILIO_PDF_TEMPLATE_SID_EN=
# TWILIO_PDF_INTERNAL_TEMPLATE_SID=

# ─── Twilio PDF/JPEG media şablonları (direkt ek dosya için önerilen) ───────
# Content Type: Media, medya URL şablonu:
# https://YOUR_PROJECT.supabase.co/storage/v1/object/public/voucher-pdfs/{{1}}
# Body değişkenleri: {{2}} ad, {{3}} bilet no, {{4}} tur, {{5}} tarih, {{6}} PDF URL
# TWILIO_PDF_MEDIA_TEMPLATE_SID_TR=
# TWILIO_PDF_MEDIA_TEMPLATE_SID_EN=
# TWILIO_PDF_MEDIA_INTERNAL_TEMPLATE_SID=

# ─── Twilio opsiyonel ─────────────────────────────────────────────────────────
# TWILIO_EASYBOOK_PHONE=+905366029397
# TWILIO_STATUS_CALLBACK_URL=https://bodrumdayiz.com.tr/api/webhooks/twilio
# TWILIO_SEND_PDF_AS_MEDIA=true  # varsayılan: JPEG ek; true ise PDF MediaUrl dener
